library (pmu_controller) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 25.0;
  nom_voltage                    : 1.80;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1 ("0.00050,  0.00159,  0.00506,  0.01608,  0.05115,  0.16265,  0.51728");
  }
  type ("current_state") {
    base_type : array;
    data_type : bit;
    bit_width : 2;
    bit_from : 1;
    bit_to : 0;
  }

  cell ("pmu_controller") {
    pin("app_idle") {
      direction : input;
      capacitance : 0.0034;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.08771");
	}
	fall_constraint(scalar) {
          values("-0.09314");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.46947");
	}
	fall_constraint(scalar) {
          values("0.35466");
	}
      }
    }
    pin("clk") {
      direction : input;
      capacitance : 0.0126;
    }
    pin("clk_gate_en") {
      direction : output;
      capacitance : 0.0000;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.07623,1.08058,1.09185,1.11931,1.19239,1.41672,2.12712");
	}
	rise_transition(template_1) {
          values("0.02227,0.02551,0.03529,0.06455,0.16181,0.48314,1.50736");
	}
	cell_fall(template_1) {
          values("1.21142,1.21534,1.22545,1.24862,1.30285,1.45493,1.93425");
	}
	fall_transition(template_1) {
          values("0.02060,0.02325,0.03048,0.05004,0.10920,0.30689,0.95356");
	}
      }
    }
    pin("isolation_en") {
      direction : output;
      capacitance : 0.0000;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.09565,1.09997,1.11121,1.13863,1.21168,1.43553,2.14477");
	}
	rise_transition(template_1) {
          values("0.02225,0.02557,0.03530,0.06465,0.16187,0.48254,1.50616");
	}
	cell_fall(template_1) {
          values("1.09195,1.09586,1.10596,1.12911,1.18328,1.33552,1.81536");
	}
	fall_transition(template_1) {
          values("0.02068,0.02331,0.03049,0.04994,0.10911,0.30677,0.94953");
	}
      }
    }
    pin("pwr_gate_en") {
      direction : output;
      capacitance : 0.0000;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.18558,1.18991,1.20117,1.22862,1.30169,1.52587,2.23589");
	}
	rise_transition(template_1) {
          values("0.02227,0.02553,0.03530,0.06458,0.16183,0.48295,1.50698");
	}
	cell_fall(template_1) {
          values("1.17619,1.18011,1.19022,1.21338,1.26759,1.41972,1.89922");
	}
	fall_transition(template_1) {
          values("0.02063,0.02327,0.03049,0.05000,0.10917,0.30684,0.95216");
	}
      }
    }
    pin("reset_n") {
      direction : input;
      capacitance : 0.0037;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.48749");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.35656");
	}
      }
    }
    pin("thermal_alert") {
      direction : input;
      capacitance : 0.0030;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.02153");
	}
	fall_constraint(scalar) {
          values("0.00148");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.02123");
	}
	fall_constraint(scalar) {
          values("0.15981");
	}
      }
    }
    pin("wakeup_event") {
      direction : input;
      capacitance : 0.0071;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.06023");
	}
	fall_constraint(scalar) {
          values("0.03690");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.41486");
	}
	fall_constraint(scalar) {
          values("0.17345");
	}
      }
    }
    pin("VPWR") {
      direction : input;
      capacitance : 0.0000;
    }
    pin("VGND") {
      direction : input;
      capacitance : 0.0000;
    }
    bus("current_state") {
      bus_type : current_state;
      direction : output;
      capacitance : 0.0000;
    pin("current_state[1]") {
      direction : output;
      capacitance : 0.0000;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("0.87623,0.88053,0.89176,0.91916,0.99220,1.21585,1.92462");
	}
	rise_transition(template_1) {
          values("0.02225,0.02559,0.03531,0.06470,0.16190,0.48229,1.50566");
	}
	cell_fall(template_1) {
          values("0.89880,0.90273,0.91292,0.93604,0.99012,1.14250,1.62270");
	}
	fall_transition(template_1) {
          values("0.02072,0.02331,0.03049,0.04989,0.10901,0.30671,0.94747");
	}
      }
    }
    pin("current_state[0]") {
      direction : output;
      capacitance : 0.0000;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("0.89422,0.89859,0.90996,0.93748,1.01058,1.23388,1.94299");
	}
	rise_transition(template_1) {
          values("0.02303,0.02635,0.03596,0.06515,0.16199,0.48194,1.50505");
	}
	cell_fall(template_1) {
          values("0.88927,0.89322,0.90352,0.92663,0.98065,1.13308,1.61337");
	}
	fall_transition(template_1) {
          values("0.02071,0.02326,0.03049,0.04990,0.10896,0.30673,0.94764");
	}
      }
    }
    }
  }

}
