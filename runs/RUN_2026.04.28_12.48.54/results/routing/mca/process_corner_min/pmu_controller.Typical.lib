library (pmu_controller) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 100.0;
  nom_voltage                    : 1.60;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1 ("0.00050,  0.00159,  0.00506,  0.01608,  0.05115,  0.16265,  0.51728");
  }
  type ("current_state") {
    base_type : array;
    data_type : bit;
    bit_width : 2;
    bit_from : 1;
    bit_to : 0;
  }

  cell ("pmu_controller") {
    pin("app_idle") {
      direction : input;
      capacitance : 0.0036;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.11942");
	}
	fall_constraint(scalar) {
          values("-0.10650");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.46682");
	}
	fall_constraint(scalar) {
          values("0.34779");
	}
      }
    }
    pin("clk") {
      direction : input;
      capacitance : 0.0119;
    }
    pin("clk_gate_en") {
      direction : output;
      capacitance : 0.0014;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.82433,1.82868,1.83995,1.86741,1.94049,2.16481,2.87522");
	}
	rise_transition(template_1) {
          values("0.02227,0.02551,0.03529,0.06455,0.16180,0.48313,1.50735");
	}
	cell_fall(template_1) {
          values("2.26210,2.26602,2.27613,2.29930,2.35353,2.50561,2.98492");
	}
	fall_transition(template_1) {
          values("0.02060,0.02324,0.03048,0.05004,0.10921,0.30689,0.95364");
	}
      }
    }
    pin("isolation_en") {
      direction : output;
      capacitance : 0.0006;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.88037,1.88468,1.89592,1.92333,1.99639,2.22021,2.92940");
	}
	rise_transition(template_1) {
          values("0.02225,0.02557,0.03530,0.06466,0.16188,0.48251,1.50610");
	}
	cell_fall(template_1) {
          values("1.95463,1.95854,1.96864,1.99179,2.04595,2.19820,2.67807");
	}
	fall_transition(template_1) {
          values("0.02069,0.02332,0.03049,0.04993,0.10911,0.30676,0.94933");
	}
      }
    }
    pin("pwr_gate_en") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("2.06021,2.06455,2.07581,2.10327,2.17634,2.40057,3.11071");
	}
	rise_transition(template_1) {
          values("0.02227,0.02552,0.03530,0.06457,0.16183,0.48301,1.50710");
	}
	cell_fall(template_1) {
          values("2.12326,2.12718,2.13729,2.16046,2.21467,2.36679,2.84623");
	}
	fall_transition(template_1) {
          values("0.02062,0.02326,0.03049,0.05001,0.10918,0.30686,0.95259");
	}
      }
    }
    pin("reset_n") {
      direction : input;
      capacitance : 0.0030;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.46636");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.31060");
	}
      }
    }
    pin("thermal_alert") {
      direction : input;
      capacitance : 0.0031;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.01758");
	}
	fall_constraint(scalar) {
          values("-0.02178");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.05162");
	}
	fall_constraint(scalar) {
          values("0.15889");
	}
      }
    }
    pin("wakeup_event") {
      direction : input;
      capacitance : 0.0036;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.00540");
	}
	fall_constraint(scalar) {
          values("-0.01893");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.44790");
	}
	fall_constraint(scalar) {
          values("0.19496");
	}
      }
    }
    bus("current_state") {
      bus_type : current_state;
      direction : output;
      capacitance : 0.0000;
    pin("current_state[1]") {
      direction : output;
      capacitance : 0.0006;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.49769,1.50199,1.51322,1.54062,1.61366,1.83729,2.54602");
	}
	rise_transition(template_1) {
          values("0.02225,0.02559,0.03531,0.06470,0.16190,0.48227,1.50561");
	}
	cell_fall(template_1) {
          values("1.60706,1.61099,1.62118,1.64431,1.69839,1.85077,2.33097");
	}
	fall_transition(template_1) {
          values("0.02072,0.02331,0.03049,0.04989,0.10901,0.30671,0.94748");
	}
      }
    }
    pin("current_state[0]") {
      direction : output;
      capacitance : 0.0009;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.50492,1.50927,1.52063,1.54813,1.62123,1.84453,2.55353");
	}
	rise_transition(template_1) {
          values("0.02295,0.02628,0.03589,0.06511,0.16198,0.48194,1.50503");
	}
	cell_fall(template_1) {
          values("1.57234,1.57630,1.58658,1.60969,1.66372,1.81615,2.29643");
	}
	fall_transition(template_1) {
          values("0.02072,0.02327,0.03049,0.04990,0.10896,0.30672,0.94762");
	}
      }
    }
    }
  }

}
