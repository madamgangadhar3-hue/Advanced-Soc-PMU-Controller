library (pmu_controller) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 100.0;
  nom_voltage                    : 1.60;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1 ("0.00050,  0.00166,  0.00553,  0.01838,  0.06111,  0.20321,  0.67567");
  }
  type ("current_state") {
    base_type : array;
    data_type : bit;
    bit_width : 2;
    bit_from : 1;
    bit_to : 0;
  }

  cell ("pmu_controller") {
    pin("app_idle") {
      direction : input;
      capacitance : 0.0038;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.07062");
	}
	fall_constraint(scalar) {
          values("-0.06120");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.27319");
	}
	fall_constraint(scalar) {
          values("0.16623");
	}
      }
    }
    pin("clk") {
      direction : input;
      capacitance : 0.0123;
    }
    pin("clk_gate_en") {
      direction : output;
      capacitance : 0.0015;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.83955,1.84278,1.85141,1.87370,1.93935,2.15336,2.86546");
	}
	rise_transition(template_1) {
          values("0.01570,0.01817,0.02599,0.05210,0.14422,0.45851,1.50056");
	}
	cell_fall(template_1) {
          values("2.27354,2.27659,2.28462,2.30331,2.34882,2.48415,2.93123");
	}
	fall_transition(template_1) {
          values("0.01540,0.01755,0.02339,0.03905,0.08872,0.26677,0.86782");
	}
      }
    }
    pin("isolation_en") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.89462,1.89789,1.90660,1.92894,1.99449,2.20875,2.91935");
	}
	rise_transition(template_1) {
          values("0.01620,0.01862,0.02636,0.05227,0.14440,0.45862,1.50128");
	}
	cell_fall(template_1) {
          values("1.96858,1.97162,1.97963,1.99831,2.04386,2.17920,2.62614");
	}
	fall_transition(template_1) {
          values("0.01540,0.01758,0.02337,0.03906,0.08871,0.26656,0.86691");
	}
      }
    }
    pin("pwr_gate_en") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("2.07814,2.08136,2.09000,2.11230,2.17793,2.39185,3.10301");
	}
	rise_transition(template_1) {
          values("0.01571,0.01816,0.02599,0.05211,0.14432,0.45856,1.49994");
	}
	cell_fall(template_1) {
          values("2.13958,2.14263,2.15066,2.16933,2.21486,2.35018,2.79699");
	}
	fall_transition(template_1) {
          values("0.01540,0.01754,0.02341,0.03906,0.08870,0.26687,0.86829");
	}
      }
    }
    pin("reset_n") {
      direction : input;
      capacitance : 0.0031;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.29799");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.19502");
	}
      }
    }
    pin("thermal_alert") {
      direction : input;
      capacitance : 0.0032;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.02309");
	}
	fall_constraint(scalar) {
          values("0.00888");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.01861");
	}
	fall_constraint(scalar) {
          values("0.04940");
	}
      }
    }
    pin("wakeup_event") {
      direction : input;
      capacitance : 0.0037;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.01014");
	}
	fall_constraint(scalar) {
          values("-0.00332");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.27230");
	}
	fall_constraint(scalar) {
          values("0.10918");
	}
      }
    }
    bus("current_state") {
      bus_type : current_state;
      direction : output;
      capacitance : 0.0000;
    pin("current_state[1]") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.50632,1.50962,1.51836,1.54071,1.60624,1.82071,2.53148");
	}
	rise_transition(template_1) {
          values("0.01645,0.01886,0.02655,0.05235,0.14439,0.45862,1.50229");
	}
	cell_fall(template_1) {
          values("1.61624,1.61926,1.62724,1.64592,1.69150,1.82690,2.27416");
	}
	fall_transition(template_1) {
          values("0.01542,0.01766,0.02328,0.03905,0.08873,0.26584,0.86373");
	}
      }
    }
    pin("current_state[0]") {
      direction : output;
      capacitance : 0.0010;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.51679,1.52021,1.52907,1.55150,1.61690,1.83228,2.54375");
	}
	rise_transition(template_1) {
          values("0.01750,0.01988,0.02734,0.05268,0.14436,0.45863,1.50648");
	}
	cell_fall(template_1) {
          values("1.58216,1.58518,1.59315,1.61182,1.65738,1.79276,2.24033");
	}
	fall_transition(template_1) {
          values("0.01547,0.01769,0.02337,0.03907,0.08877,0.26580,0.86368");
	}
      }
    }
    }
  }

}
