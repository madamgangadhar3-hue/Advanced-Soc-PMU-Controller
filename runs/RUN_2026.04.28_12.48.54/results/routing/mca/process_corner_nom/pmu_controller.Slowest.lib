library (pmu_controller) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 100.0;
  nom_voltage                    : 1.60;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1 ("0.00050,  0.00181,  0.00654,  0.02365,  0.08552,  0.30928,  1.11848");
  }
  type ("current_state") {
    base_type : array;
    data_type : bit;
    bit_width : 2;
    bit_from : 1;
    bit_to : 0;
  }

  cell ("pmu_controller") {
    pin("app_idle") {
      direction : input;
      capacitance : 0.0036;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.26664");
	}
	fall_constraint(scalar) {
          values("-0.26800");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("1.07834");
	}
	fall_constraint(scalar) {
          values("0.80252");
	}
      }
    }
    pin("clk") {
      direction : input;
      capacitance : 0.0122;
    }
    pin("clk_gate_en") {
      direction : output;
      capacitance : 0.0015;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.83538,1.84452,1.86953,1.93620,2.13686,2.84438,5.39860");
	}
	rise_transition(template_1) {
          values("0.03918,0.04584,0.06722,0.13826,0.40718,1.40139,4.99298");
	}
	cell_fall(template_1) {
          values("2.27021,2.27803,2.30024,2.35638,2.51226,3.04845,4.97442");
	}
	fall_transition(template_1) {
          values("0.03435,0.03976,0.05686,0.10961,0.30109,1.02077,3.64132");
	}
      }
    }
    pin("isolation_en") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.89396,1.90304,1.92819,1.99465,2.19530,2.90278,5.45693");
	}
	rise_transition(template_1) {
          values("0.03927,0.04588,0.06710,0.13828,0.40707,1.40262,4.99599");
	}
	cell_fall(template_1) {
          values("1.96805,1.97578,1.99803,2.05407,2.21043,2.74649,4.67187");
	}
	fall_transition(template_1) {
          values("0.03436,0.03975,0.05692,0.10971,0.30107,1.02088,3.64114");
	}
      }
    }
    pin("pwr_gate_en") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("2.07729,2.08642,2.11146,2.17808,2.37874,3.08624,5.64045");
	}
	rise_transition(template_1) {
          values("0.03921,0.04585,0.06719,0.13827,0.40716,1.40170,4.99373");
	}
	cell_fall(template_1) {
          values("2.13890,2.14672,2.16894,2.22505,2.38110,2.91725,4.84271");
	}
	fall_transition(template_1) {
          values("0.03435,0.03975,0.05688,0.10964,0.30107,1.02078,3.64095");
	}
      }
    }
    pin("reset_n") {
      direction : input;
      capacitance : 0.0030;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.92563");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.60231");
	}
      }
    }
    pin("thermal_alert") {
      direction : input;
      capacitance : 0.0031;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.00421");
	}
	fall_constraint(scalar) {
          values("-0.14806");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.13865");
	}
	fall_constraint(scalar) {
          values("0.41905");
	}
      }
    }
    pin("wakeup_event") {
      direction : input;
      capacitance : 0.0036;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.06266");
	}
	fall_constraint(scalar) {
          values("-0.07226");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.98790");
	}
	fall_constraint(scalar) {
          values("0.48517");
	}
      }
    }
    bus("current_state") {
      bus_type : current_state;
      direction : output;
      capacitance : 0.0000;
    pin("current_state[1]") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.50566,1.51470,1.53992,1.60629,1.80694,2.51439,5.06852");
	}
	rise_transition(template_1) {
          values("0.03931,0.04589,0.06704,0.13829,0.40702,1.40313,4.99724");
	}
	cell_fall(template_1) {
          values("1.61575,1.62308,1.64529,1.70128,1.85767,2.39354,4.32342");
	}
	fall_transition(template_1) {
          values("0.03443,0.03977,0.05701,0.10977,0.30114,1.02121,3.64563");
	}
      }
    }
    pin("current_state[0]") {
      direction : output;
      capacitance : 0.0010;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.51491,1.52393,1.54931,1.61555,1.81620,2.52370,5.07779");
	}
	rise_transition(template_1) {
          values("0.03958,0.04611,0.06712,0.13841,0.40693,1.40418,4.99969");
	}
	cell_fall(template_1) {
          values("1.58080,1.58793,1.61012,1.66609,1.82250,2.35828,4.29037");
	}
	fall_transition(template_1) {
          values("0.03446,0.03978,0.05706,0.10980,0.30117,1.02137,3.64784");
	}
      }
    }
    }
  }

}
