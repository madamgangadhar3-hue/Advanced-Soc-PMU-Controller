library (pmu_controller) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 100.0;
  nom_voltage                    : 1.60;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1 ("0.00050,  0.00159,  0.00506,  0.01608,  0.05115,  0.16265,  0.51728");
  }
  type ("current_state") {
    base_type : array;
    data_type : bit;
    bit_width : 2;
    bit_from : 1;
    bit_to : 0;
  }

  cell ("pmu_controller") {
    pin("app_idle") {
      direction : input;
      capacitance : 0.0037;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.12715");
	}
	fall_constraint(scalar) {
          values("-0.11209");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.47052");
	}
	fall_constraint(scalar) {
          values("0.35051");
	}
      }
    }
    pin("clk") {
      direction : input;
      capacitance : 0.0122;
    }
    pin("clk_gate_en") {
      direction : output;
      capacitance : 0.0015;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.83835,1.84270,1.85397,1.88143,1.95451,2.17884,2.88924");
	}
	rise_transition(template_1) {
          values("0.02227,0.02551,0.03529,0.06455,0.16181,0.48314,1.50736");
	}
	cell_fall(template_1) {
          values("2.27257,2.27649,2.28661,2.30978,2.36400,2.51609,2.99541");
	}
	fall_transition(template_1) {
          values("0.02060,0.02325,0.03048,0.05004,0.10920,0.30689,0.95351");
	}
      }
    }
    pin("isolation_en") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.89444,1.89875,1.90999,1.93740,2.01045,2.23423,2.94330");
	}
	rise_transition(template_1) {
          values("0.02225,0.02557,0.03531,0.06467,0.16188,0.48245,1.50598");
	}
	cell_fall(template_1) {
          values("1.96842,1.97233,1.98243,2.00558,2.05974,2.21200,2.69192");
	}
	fall_transition(template_1) {
          values("0.02069,0.02332,0.03049,0.04992,0.10910,0.30675,0.94892");
	}
      }
    }
    pin("pwr_gate_en") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("2.07790,2.08224,2.09350,2.12095,2.19402,2.41822,3.12829");
	}
	rise_transition(template_1) {
          values("0.02227,0.02553,0.03530,0.06458,0.16183,0.48297,1.50703");
	}
	cell_fall(template_1) {
          values("2.13938,2.14330,2.15341,2.17657,2.23078,2.38291,2.86239");
	}
	fall_transition(template_1) {
          values("0.02062,0.02327,0.03049,0.05001,0.10918,0.30685,0.95235");
	}
      }
    }
    pin("reset_n") {
      direction : input;
      capacitance : 0.0030;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.46640");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.30803");
	}
      }
    }
    pin("thermal_alert") {
      direction : input;
      capacitance : 0.0032;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.01440");
	}
	fall_constraint(scalar) {
          values("-0.02409");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.05654");
	}
	fall_constraint(scalar) {
          values("0.15974");
	}
      }
    }
    pin("wakeup_event") {
      direction : input;
      capacitance : 0.0037;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.00044");
	}
	fall_constraint(scalar) {
          values("-0.02336");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.45370");
	}
	fall_constraint(scalar) {
          values("0.19858");
	}
      }
    }
    bus("current_state") {
      bus_type : current_state;
      direction : output;
      capacitance : 0.0000;
    pin("current_state[1]") {
      direction : output;
      capacitance : 0.0007;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.50614,1.51044,1.52166,1.54906,1.62210,1.84569,2.55433");
	}
	rise_transition(template_1) {
          values("0.02224,0.02559,0.03531,0.06471,0.16191,0.48222,1.50552");
	}
	cell_fall(template_1) {
          values("1.61608,1.62001,1.63021,1.65333,1.70741,1.85979,2.34000");
	}
	fall_transition(template_1) {
          values("0.02072,0.02330,0.03049,0.04989,0.10901,0.30671,0.94749");
	}
      }
    }
    pin("current_state[0]") {
      direction : output;
      capacitance : 0.0010;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.51628,1.52065,1.53204,1.55957,1.63268,1.85597,2.56517");
	}
	rise_transition(template_1) {
          values("0.02310,0.02641,0.03601,0.06519,0.16199,0.48194,1.50506");
	}
	cell_fall(template_1) {
          values("1.58167,1.58562,1.59593,1.61903,1.67305,1.82549,2.30577");
	}
	fall_transition(template_1) {
          values("0.02071,0.02326,0.03050,0.04990,0.10896,0.30673,0.94764");
	}
      }
    }
    }
  }

}
