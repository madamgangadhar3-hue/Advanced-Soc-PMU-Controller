        + PLACED ( 9890 48000 ) N ;
    - wakeup_event + NET wakeup_event + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met3 ( -2000 -300 ) ( 2000 300 )
        + PLACED ( 48000 7140 ) N ;
END PINS
NETS 18 ;
    - _00_ ( _18_ D ) ( _15_ X ) + USE SIGNAL ;
    - _01_ ( _19_ D ) ( _17_ Y ) + USE SIGNAL ;
    - _02_ ( _09_ A ) ( _08_ X ) + USE SIGNAL ;
    - _03_ ( _11_ A ) ( _10_ X ) + USE SIGNAL ;
    - _04_ ( _15_ A1 ) ( _12_ X ) + USE SIGNAL ;
    - _05_ ( _15_ A2 ) ( _13_ X ) + USE SIGNAL ;
    - _06_ ( _15_ B1 ) ( _14_ Y ) + USE SIGNAL ;
    - _07_ ( _17_ A2 ) ( _16_ Y ) + USE SIGNAL ;
    - app_idle ( PIN app_idle ) ( _16_ A2 ) ( _14_ C_N ) ( _12_ B_N ) + USE SIGNAL ;
    - clk ( PIN clk ) ( _19_ CLK ) ( _18_ CLK ) + USE SIGNAL ;
    - clk_gate_en ( PIN clk_gate_en ) ( _11_ X ) + USE SIGNAL ;
    - current_state[0] ( PIN current_state[0] ) ( _18_ Q ) ( _16_ A1 ) ( _14_ B ) ( _13_ B ) ( _10_ B ) + USE SIGNAL ;
    - current_state[1] ( PIN current_state[1] ) ( _19_ Q ) ( _16_ B1 ) ( _14_ A ) ( _12_ A ) ( _10_ A ) ( _08_ A ) + USE SIGNAL ;
    - isolation_en ( PIN isolation_en ) ( _20_ A ) ( _09_ X ) + USE SIGNAL ;
    - pwr_gate_en ( PIN pwr_gate_en ) ( _20_ X ) + USE SIGNAL ;
    - reset_n ( PIN reset_n ) ( _19_ RESET_B ) ( _18_ RESET_B ) + USE SIGNAL ;
    - thermal_alert ( PIN thermal_alert ) ( _17_ B1_N ) ( _15_ C1 ) + USE SIGNAL ;
    - wakeup_event ( PIN wakeup_event ) ( _17_ A1 ) ( _13_ A_N ) + USE SIGNAL ;
END NETS
END DESIGN
