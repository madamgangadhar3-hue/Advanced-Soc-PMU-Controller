VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN pmu_controller ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 50000 50000 ) ;
ROW ROW_0 unithd 5520 10880 N DO 84 BY 1 STEP 460 0 ;
