PINS 10 ;
    - app_idle + NET app_idle + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -140 -2000 ) ( 140 2000 )
        + PLACED ( 48530 48000 ) N ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -140 -2000 ) ( 140 2000 )
        + PLACED ( 230 2000 ) N ;
    - clk_gate_en + NET clk_gate_en + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -140 -2000 ) ( 140 2000 )
        + PLACED ( 29210 48000 ) N ;
    - current_state[0] + NET current_state[0] + DIRECTION OUTPUT + USE SIGNAL
      + PORT
