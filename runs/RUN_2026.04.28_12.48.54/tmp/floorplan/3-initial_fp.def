VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN pmu_controller ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 50000 50000 ) ;
ROW ROW_0 unithd 5520 10880 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_1 unithd 5520 13600 FS DO 84 BY 1 STEP 460 0 ;
ROW ROW_2 unithd 5520 16320 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_3 unithd 5520 19040 FS DO 84 BY 1 STEP 460 0 ;
ROW ROW_4 unithd 5520 21760 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_5 unithd 5520 24480 FS DO 84 BY 1 STEP 460 0 ;
ROW ROW_6 unithd 5520 27200 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_7 unithd 5520 29920 FS DO 84 BY 1 STEP 460 0 ;
ROW ROW_8 unithd 5520 32640 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_9 unithd 5520 35360 FS DO 84 BY 1 STEP 460 0 ;
TRACKS X 230 DO 109 STEP 460 LAYER li1 ;
TRACKS Y 170 DO 147 STEP 340 LAYER li1 ;
TRACKS X 170 DO 147 STEP 340 LAYER met1 ;
TRACKS Y 170 DO 147 STEP 340 LAYER met1 ;
TRACKS X 230 DO 109 STEP 460 LAYER met2 ;
TRACKS Y 230 DO 109 STEP 460 LAYER met2 ;
TRACKS X 340 DO 73 STEP 680 LAYER met3 ;
TRACKS Y 340 DO 73 STEP 680 LAYER met3 ;
TRACKS X 460 DO 54 STEP 920 LAYER met4 ;
TRACKS Y 460 DO 54 STEP 920 LAYER met4 ;
TRACKS X 1700 DO 14 STEP 3400 LAYER met5 ;
TRACKS Y 1700 DO 14 STEP 3400 LAYER met5 ;
COMPONENTS 13 ;
    - _08_ sky130_fd_sc_hd__buf_1 ;
    - _09_ sky130_fd_sc_hd__buf_1 ;
    - _10_ sky130_fd_sc_hd__or2_2 ;
    - _11_ sky130_fd_sc_hd__buf_1 ;
    - _12_ sky130_fd_sc_hd__or2b_2 ;
    - _13_ sky130_fd_sc_hd__and2b_2 ;
    - _14_ sky130_fd_sc_hd__nor3b_2 ;
    - _15_ sky130_fd_sc_hd__a211o_2 ;
    - _16_ sky130_fd_sc_hd__a21oi_2 ;
    - _17_ sky130_fd_sc_hd__o21bai_2 ;
    - _18_ sky130_fd_sc_hd__dfrtp_2 ;
    - _19_ sky130_fd_sc_hd__dfrtp_2 ;
    - _20_ sky130_fd_sc_hd__buf_2 ;
END COMPONENTS
PINS 10 ;
    - app_idle + NET app_idle + DIRECTION INPUT + USE SIGNAL ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL ;
    - clk_gate_en + NET clk_gate_en + DIRECTION OUTPUT + USE SIGNAL ;
    - current_state[0] + NET current_state[0] + DIRECTION OUTPUT + USE SIGNAL ;
    - current_state[1] + NET current_state[1] + DIRECTION OUTPUT + USE SIGNAL ;
    - isolation_en + NET isolation_en + DIRECTION OUTPUT + USE SIGNAL ;
    - pwr_gate_en + NET pwr_gate_en + DIRECTION OUTPUT + USE SIGNAL ;
    - reset_n + NET reset_n + DIRECTION INPUT + USE SIGNAL ;
    - thermal_alert + NET thermal_alert + DIRECTION INPUT + USE SIGNAL ;
    - wakeup_event + NET wakeup_event + DIRECTION INPUT + USE SIGNAL ;
END PINS
NETS 18 ;
    - _00_ ( _18_ D ) ( _15_ X ) + USE SIGNAL ;
    - _01_ ( _19_ D ) ( _17_ Y ) + USE SIGNAL ;
    - _02_ ( _09_ A ) ( _08_ X ) + USE SIGNAL ;
    - _03_ ( _11_ A ) ( _10_ X ) + USE SIGNAL ;
    - _04_ ( _15_ A1 ) ( _12_ X ) + USE SIGNAL ;
    - _05_ ( _15_ A2 ) ( _13_ X ) + USE SIGNAL ;
    - _06_ ( _15_ B1 ) ( _14_ Y ) + USE SIGNAL ;
    - _07_ ( _17_ A2 ) ( _16_ Y ) + USE SIGNAL ;
    - app_idle ( PIN app_idle ) ( _16_ A2 ) ( _14_ C_N ) ( _12_ B_N ) + USE SIGNAL ;
    - clk ( PIN clk ) ( _19_ CLK ) ( _18_ CLK ) + USE SIGNAL ;
    - clk_gate_en ( PIN clk_gate_en ) ( _11_ X ) + USE SIGNAL ;
    - current_state[0] ( PIN current_state[0] ) ( _18_ Q ) ( _16_ A1 ) ( _14_ B ) ( _13_ B ) ( _10_ B ) + USE SIGNAL ;
    - current_state[1] ( PIN current_state[1] ) ( _19_ Q ) ( _16_ B1 ) ( _14_ A ) ( _12_ A ) ( _10_ A ) ( _08_ A ) + USE SIGNAL ;
    - isolation_en ( PIN isolation_en ) ( _20_ A ) ( _09_ X ) + USE SIGNAL ;
    - pwr_gate_en ( PIN pwr_gate_en ) ( _20_ X ) + USE SIGNAL ;
    - reset_n ( PIN reset_n ) ( _19_ RESET_B ) ( _18_ RESET_B ) + USE SIGNAL ;
    - thermal_alert ( PIN thermal_alert ) ( _17_ B1_N ) ( _15_ C1 ) + USE SIGNAL ;
    - wakeup_event ( PIN wakeup_event ) ( _17_ A1 ) ( _13_ A_N ) + USE SIGNAL ;
END NETS
END DESIGN
